[Unit]
Description=HAFSQuiz Flask Application
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/HAFSQuiz
Environment="PATH=/home/ubuntu/HAFSQuiz/venv/bin"
EnvironmentFile=/home/ubuntu/HAFSQuiz/.env
ExecStart=/home/ubuntu/HAFSQuiz/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
